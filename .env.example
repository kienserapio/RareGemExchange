# Base URL of the deployed backend API (no trailing slash).
# Copy this file to ".env.local" (git-ignored) and set your real backend URL,
# or define VITE_API_URL in your frontend host's environment variables.
#
# Leave it unset to fall back to relative "/api" paths (Vite dev proxy locally).
VITE_API_URL=https://your-backend.onrender.com
